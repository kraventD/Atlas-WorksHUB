---
import Layout from "@/layouts/Layout.astro"
import { createSupabaseServerClient } from "@/lib/supabase/server"
import { ADMIN_EMAIL } from "@/lib/constants"

const supabase = createSupabaseServerClient(Astro.cookies)
const { data: { session } } = await supabase.auth.getSession()

if (!session?.user) {
  return Astro.redirect("/login")
}

const { data: profile } = await supabase
  .from("profiles")
  .select("*")
  .eq("id", session.user.id)
  .single()

const displayName = profile?.display_name || session.user.user_metadata?.full_name || ""
const bio = profile?.bio || ""
const avatarUrl = profile?.avatar_url || session.user.user_metadata?.avatar_url || ""
const email = session.user.email || ""
const profilePublic = profile?.profile_public || false
const isAdmin = email === ADMIN_EMAIL
const success = Astro.url.searchParams.get("saved") === "true"

const avatarOptions = [
  { id: "default", label: "Iniciales", url: null },
  { id: "avatar1", label: "Avatar 1", url: "/images/avatars/avatar-1.png" },
  { id: "avatar2", label: "Avatar 2", url: "/images/avatars/avatar-2.png" },
  { id: "avatar3", label: "Avatar 3", url: "/images/avatars/avatar-3.png" },
  { id: "avatar4", label: "Avatar 4", url: "/images/avatars/avatar-4.png" },
  { id: "avatar5", label: "Avatar 5", url: "/images/avatars/avatar-5.png" },
  { id: "avatar6", label: "Avatar 6", url: "/images/avatars/avatar-6.png" },
  { id: "avatar7", label: "Avatar 7", url: "/images/avatars/avatar-7.png" },
  { id: "avatar8", label: "Avatar 8", url: "/images/avatars/avatar-8.png" },
  { id: "avatar9", label: "Avatar 9", url: "/images/avatars/avatar-9.png" },
  { id: "avatar10", label: "Avatar 10", url: "/images/avatars/avatar-10.png" },
  ...(isAdmin ? [{ id: "admin", label: "Admin", url: "/images/avatars/avatar-admin.png" }] : []),
]

const currentAvatar = avatarUrl || ""

const isCurrentAvatar = (url) => {
  if (!avatarUrl) return url === null
  return avatarUrl === url
}

---

<Layout title="Ajustes — Oribius Discovery" currentPath={Astro.url.pathname}>
<main class="min-h-screen bg-[#0A0A0A] pt-8">
  <div class="max-w-lg mx-auto px-4">
    <a href="/perfil" class="inline-flex items-center gap-2 text-gray-500 hover:text-white transition-colors text-sm mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Volver al perfil
    </a>

    <h1 class="text-2xl font-bold text-white mb-8">Ajustes</h1>

    {success && (
      <div class="bg-green-600/20 border border-green-600/50 rounded-lg px-4 py-3 text-green-400 text-sm mb-6">
        Cambios guardados correctamente
      </div>
    )}

    <form method="POST" action="/api/auth/update-profile" class="space-y-6">
      <div class="flex items-center gap-4">
        <div class="relative">
          {avatarUrl ? (
            <img src={avatarUrl} alt="" class="h-16 w-16 rounded-full object-cover border-2 border-orange-500/50" />
          ) : (
            <div class="h-16 w-16 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-xl font-bold text-white">
              {(displayName || email).charAt(0).toUpperCase()}
            </div>
          )}
          <div>
            <p class="text-white text-sm font-medium">{displayName || email}</p>
            <p class="text-gray-500 text-xs">{email}</p>
          </div>
        </div>
        </div>

        <div class="mt-6">
          <p class="text-gray-400 text-sm mb-3">Avatar</p>
          <div class="grid grid-cols-5 gap-3">
            {avatarOptions.map((opt) => (
              <button
                type="button"
                data-avatar-id={opt.id}
                class={`avatar-btn relative aspect-square rounded-xl border-2 transition-all cursor-pointer ${
                  isCurrentAvatar(opt.url) ? "ring-2 ring-orange-500" : "border-transparent"
                } hover:ring-2 hover:ring-orange-500/50`}
              >
                {opt.url ? (
                  <img src={opt.url} alt={opt.label} class="w-full h-full rounded-xl object-cover" />
                ) : (
                  <div class="w-full h-full rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-2xl font-bold text-white">
                    {(displayName || email).charAt(0).toUpperCase()}
                  </div>
                )}
              </button>
            ))}
          </div>
        </div>

        <!-- Privacy toggle -->
        <div class="flex items-center justify-between py-3 px-4 rounded-lg bg-dark-800/50 border border-dark-700/50">
          <div>
            <p class="text-white text-sm font-medium">Perfil público</p>
            <p class="text-gray-500 text-xs mt-0.5">Cualquier persona puede ver tu perfil y estadísticas</p>
          </div>
          <button
            type="button"
            id="privacy-toggle"
            data-active={profilePublic ? "true" : "false"}
            class={`relative w-11 h-6 rounded-full transition-colors duration-200 ${
              profilePublic ? "bg-orange-500" : "bg-dark-700"
            }`}
          >
            <span
              class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white transition-transform duration-200 shadow"
              style={`transform: translateX(${profilePublic ? "20px" : "0"})`}
            />
          </button>
        </div>

        <div>
          <label for="display_name" class="text-gray-400 text-sm block mb-1">Nombre público</label>
          <input id="display_name" name="display_name" value={displayName} class="w-full h-10 rounded-lg bg-dark-800 border border-dark-700 px-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-orange-500/50" />
        </div>

        <div>
          <label for="bio" class="text-gray-400 text-sm block mb-1">Biografía</label>
          <textarea id="bio" name="bio" rows="3" class="w-full rounded-lg bg-dark-800 border border-dark-700 px-3 py-2 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-orange-500/50 resize-none">{bio}</textarea>
        </div>

        <button type="submit" class="w-full h-10 rounded-lg bg-orange-500 text-black font-bold text-sm hover:bg-orange-600 transition-colors">
          GUARDAR CAMBIOS
        </button>
      </form>
    </div>
  </main>
</Layout>

<script>
  document.querySelectorAll(".avatar-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const res = await fetch("/api/auth/update-avatar", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ avatarId: btn.getAttribute("data-avatar-id") }),
      })
      if (res.ok) {
        window.location.reload()
      }
    })
  })

  const privacyToggle = document.getElementById("privacy-toggle")
  privacyToggle?.addEventListener("click", async () => {
    const current = privacyToggle.getAttribute("data-active") === "true"
    const next = !current
    const res = await fetch("/api/auth/update-privacy", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ profile_public: next }),
    })
    if (res.ok) {
      privacyToggle.setAttribute("data-active", next ? "true" : "false")
      privacyToggle.className = `relative w-11 h-6 rounded-full transition-colors duration-200 ${next ? "bg-orange-500" : "bg-dark-700"}`
      const span = privacyToggle.querySelector("span")
      if (span) span.style.transform = `translateX(${next ? "20px" : "0"})`
      window.dispatchEvent(new CustomEvent("xp-toast", { detail: { message: next ? "Perfil público ✓" : "Perfil privado ✓" } }))
    }
  })
</script>