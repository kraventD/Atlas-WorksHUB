---
import Layout from "@/layouts/Layout.astro";
import { getTopGames } from "@/lib/sanity/client";
import { gameImg, imgUrl } from "@/lib/images";
import { Sword, Shield, Compass, Skull, Castle, Trophy, Heart, Users, Plus } from "lucide-react"

const juegosPopulares = await getTopGames(6);

const categorias = [
  { name: "Acción", Icon: Sword, image: "/images/categories/accion.png" },
  { name: "RPG", Icon: Shield, image: "/images/categories/rpg.png" },
  { name: "Aventura", Icon: Compass, image: "/images/categories/aventura.png" },
  { name: "Terror", Icon: Skull, image: "/images/categories/terror.png" },
  { name: "Estrategia", Icon: Castle, image: "/images/categories/estrategia.png" },
  { name: "Deportes", Icon: Trophy, image: "/images/categories/deportes.png" },
  { name: "Indie", Icon: Heart, image: "/images/categories/indie.png" },
  { name: "Multijugador", Icon: Users, image: "/images/categories/multijugador.png" },
]
---

<Layout title="Oribius Discovery — Explora, descubre y juega" currentPath={Astro.url.pathname}>
  <main class="min-h-screen">
    <!-- Hero section with fade to black -->
    <section class="relative h-screen w-full overflow-hidden flex flex-col">
      <!-- Hero background image -->
      <img src="/images/hero-bg.avif" alt="" class="absolute inset-0 h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-dark-950/95 via-dark-950/60 to-transparent" />
      <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-dark-950/20 to-transparent" />

      <!-- Decorative elements -->
      <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-orange-500/10 rounded-full blur-[128px]" />
      <div class="absolute bottom-1/4 left-1/3 w-64 h-64 bg-orange-600/5 rounded-full blur-[96px]" />

      <!-- Hero content -->
      <div class="relative z-10 flex-1 flex px-8 pt-[88px]">
        <div class="max-w-2xl animate-fade-in">
          <div class="space-y-6">
            <p class="text-sm font-medium tracking-widest text-orange-500 uppercase">
              Juego destacado
            </p>
            <h1 class="font-display text-4xl md:text-6xl font-bold leading-tight">
              ELDEN RING
            </h1>
            <p class="text-lg text-gray-300 leading-relaxed max-w-xl">
              El nuevo juego de rol y acción de FromSoftware. 
              Explora las Tierras Intermedias y enfréntate a 
              criaturas legendarias en un mundo abierto lleno de misterio.
            </p>
            <div class="flex items-center gap-4">
              <a
                href="/juego/elden-ring"
                class="inline-flex items-center justify-center h-11 px-8 rounded-lg bg-orange-500 text-white font-medium text-sm transition-all duration-200 hover:bg-orange-600 shadow-lg shadow-orange-500/25 gap-2"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Ver trailer
              </a>
              <a
                href="/juego/elden-ring"
                class="inline-flex items-center justify-center h-11 px-8 rounded-lg border border-dark-700 bg-transparent text-white font-medium text-sm transition-all duration-200 hover:bg-dark-800"
              >
                Más información
              </a>
            </div>
          </div>
        </div>

        <div class="hidden md:block ml-auto mr-8 space-y-5 animate-fade-in">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EAB308" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <div>
              <p class="text-2xl font-bold">9.2</p>
              <p class="text-xs text-gray-400">Calificación</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <div>
              <p class="text-2xl font-bold">2022</p>
              <p class="text-xs text-gray-400">Año</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <div>
              <p class="text-2xl font-bold">1-4</p>
              <p class="text-xs text-gray-400">Jugadores</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4ADE80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <div>
              <p class="text-2xl font-bold">60h</p>
              <p class="text-xs text-gray-400">Duración</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Juegos populares -->
    <section class="relative z-10 -mt-72 pb-24 px-8">
      <div>
        <h2 class="font-display text-2xl font-bold mb-6">Juegos populares</h2>
        <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-7 gap-4 card-grid">
          {juegosPopulares.map((juego) => (
            <a href={`/juego/${juego.slug}`} class="game-card group cursor-pointer">
              <div class="relative h-80 rounded-xl bg-dark-900 border border-dark-800/50 transition-all duration-300 group-hover:border-orange-500/30 group-hover:shadow-lg group-hover:shadow-orange-500/10">
                <div class="absolute inset-0 rounded-xl overflow-hidden">
                  {(juego.cover_url || juego.image) && <img src={gameImg(juego, 400)} alt={juego.title} class="h-full w-full object-cover" />}
                  <div class="absolute bottom-0 left-0 right-0 h-[40%] bg-gradient-to-t from-dark-950/90 via-dark-950/40 to-transparent" />
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-4">
                  <p class="text-sm font-bold text-white group-hover:text-orange-400 transition-colors">{juego.title}</p>
                  <div class="flex items-center gap-1 mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#EAB308" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <span class="text-xs text-gray-400">{juego.rating?.toFixed(1) || "N/A"}</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
          <!-- CTA card -->
          <a href="/explorar" class="game-card group cursor-pointer">
            <div class="relative h-80 rounded-xl bg-gradient-to-br from-dark-900 to-dark-950 border border-dark-800/50 transition-all duration-300 group-hover:border-orange-500/30 group-hover:shadow-lg group-hover:shadow-orange-500/10 flex items-center justify-center">
              <div class="text-center p-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 opacity-60 group-hover:opacity-100 transition-opacity"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
                <p class="text-white font-semibold text-sm">Ver todos</p>
                <p class="text-gray-500 text-xs mt-1">los juegos</p>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Categorías -->
    <section class="relative z-10 px-8 pb-16">
      <h2 class="font-display text-2xl font-bold mb-6">Explora por géneros</h2>
        <div class="flex flex-wrap gap-3">
        {categorias.map((cat) => (
          <a
            href={`/explorar?genero=${cat.name.toLowerCase()}`}
            class="group relative flex-1 min-w-[calc(50%-6px)] md:min-w-0 h-28 rounded-xl overflow-hidden cursor-pointer border border-dark-800/50 transition-all duration-300 hover:border-orange-500/30 hover:shadow-lg hover:shadow-orange-500/10 bg-cover bg-center"
            style={`background-image: url('${cat.image}')`}
          >
            <div class="absolute inset-0 bg-dark-950/60 group-hover:bg-dark-950/40 transition-colors" />
            <div class="relative h-full flex flex-col items-center justify-center gap-2">
              <cat.Icon className="h-6 w-6 text-orange-500 opacity-70 group-hover:opacity-100 transition-opacity" />
              <span class="text-xs font-medium text-gray-300 group-hover:text-white transition-colors">{cat.name}</span>
            </div>
          </a>
        ))}
        <a
          href="/explorar"
          class="group relative flex-1 min-w-[calc(50%-6px)] md:min-w-0 h-28 rounded-xl overflow-hidden cursor-pointer border border-dashed border-dark-700/50 transition-all duration-300 hover:border-orange-500/30 hover:shadow-lg hover:shadow-orange-500/10 bg-dark-900/50"
        >
          <div class="relative h-full flex flex-col items-center justify-center gap-2">
            <Plus className="h-6 w-6 text-gray-500 group-hover:text-orange-500 transition-colors" />
            <span class="text-xs font-medium text-gray-500 group-hover:text-white transition-colors">Otros géneros</span>
          </div>
        </a>
      </div>
    </section>

    <!-- CTA Explorar -->
    <section class="relative z-10 px-8 pb-24">
      <div class="flex flex-col items-center gap-4 py-16 rounded-2xl border border-dark-800/50 bg-gradient-to-b from-dark-900/50 to-dark-950/50">
        <h2 class="font-display text-3xl font-bold text-center">Descubre todos los juegos</h2>
        <p class="text-gray-400 text-center max-w-md">
          Explora nuestra colección curada de los mejores videojuegos. Cada título ha sido seleccionado por su calidad y experiencia única.
        </p>
        <a
          href="/explorar"
          class="inline-flex items-center justify-center h-12 px-8 rounded-lg bg-orange-500 text-white font-medium transition-all duration-200 hover:bg-orange-600 shadow-lg shadow-orange-500/25 gap-2"
        >
          Explorar todos los juegos
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </section>
  </main>
</Layout>
